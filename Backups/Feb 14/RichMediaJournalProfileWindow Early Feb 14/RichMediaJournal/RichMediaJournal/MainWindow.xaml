<Window
    x:Class="RichMediaJournal.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Chat UI"
    Width="1000"
    Height="600"
    Background="#222">

    <Grid>
        <Grid
            x:Name="Sidebar"
            Width="200"
            HorizontalAlignment="Left"
            Background="#333">
            <StackPanel>
                <Button Click="ToggleSidebar_Click" Content="Toggle Sidebar" />

                <Button
                    Margin="5"
                    Background="#555"
                    Click="SwitchToNotes_Click"
                    Content="Notes"
                    Foreground="White" />
                <Button
                    Margin="5"
                    Background="#555"
                    Click="SwitchToLocal_Click"
                    Content="Local"
                    Foreground="White" />

                <ListBox
                    x:Name="BranchCategoryList"
                    Background="#444"
                    Foreground="White" />

                <Grid Margin="5">
                    <TextBox
                        x:Name="NewCategoryInput"
                        Width="180"
                        Background="#555"
                        Foreground="White"
                        GotFocus="ClearPlaceholderText"
                        LostFocus="RestorePlaceholderText">
                        Enter category name
                    </TextBox>
                </Grid>
                <Button Click="AddCategory_Click" Content="+ Add Category" />
            </StackPanel>
        </Grid>

        <Grid
            x:Name="ChannelPanel"
            Width="200"
            Margin="200,0,0,0"
            HorizontalAlignment="Left"
            Background="#444">
            <StackPanel>
                <TextBlock
                    Margin="5"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="Channels" />
                <ListBox
                    x:Name="ChannelList"
                    Background="#555"
                    Foreground="White" />

                <Grid Margin="5">
                    <TextBox
                        x:Name="NewChannelInput"
                        Width="180"
                        Background="#666"
                        Foreground="White"
                        GotFocus="ClearPlaceholderText"
                        LostFocus="RestorePlaceholderText">
                        Enter channel name
                    </TextBox>
                </Grid>
                <Button Click="AddChannel_Click" Content="+ Add Channel" />
            </StackPanel>
        </Grid>

        <Grid Margin="400,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="30" />
                <RowDefinition Height="*" />
                <RowDefinition Height="50" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="5"
                Background="#222">
                <TextBlock
                    x:Name="ChatTitleBar"
                    VerticalAlignment="Center"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="Notes #General"
                    TextAlignment="Center" />
            </Border>

            <ScrollViewer Grid.Row="1" Background="#111">
                <StackPanel x:Name="ChatHistory" />
            </ScrollViewer>

            <Grid
                x:Name="ButtonsStackPanel"
                Grid.Row="2"
                Background="#333"
                ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="50" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="MessageInput"
                    Grid.Column="1"
                    Height="40"
                    Margin="5"
                    VerticalAlignment="Center"
                    Background="#555"
                    Foreground="White"
                    KeyDown="MessageInput_KeyDown" />

                <Button
                    Grid.Column="3"
                    Width="50"
                    Margin="5"
                    HorizontalAlignment="Center"
                    Click="SendMessage_Click"
                    Content="Send" />
                <StackPanel>
                    <Button
                        Width="24"
                        Height="22"
                        Click="AttachFile_Click"
                        Content="+" />
                    <Button
                        x:Name="SettingsButton"
                        Width="30"
                        Height="25"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="SettingsButton_Click">
                        <Image
                            Width="27"
                            Height="25"
                            Margin="0,2,0,4"
                            Source="{Binding Source={StaticResource SettingsIcon}}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>