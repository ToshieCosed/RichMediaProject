<Window
    x:Class="RichMediaJournal.ProfileSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:RichMediaJournal"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ProfileSettings"
    HorizontalAlignment="Center"
    VerticalAlignment="Center"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="171*" />
            <ColumnDefinition Width="629*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="ProfileDisplay"
            Margin="0,0,71,305"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            RenderTransformOrigin="0.524,0.374">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="Black" />
                    <GradientStop Offset="1" Color="#FFFEFFFE" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="25" />
                <RowDefinition Height="100" />
            </Grid.RowDefinitions>
            <Label
                x:Name="ProfileMenuCurrentUser"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="#FF68717B"
                Content="UserName"
                FontSize="14"
                FontWeight="Bold">
                <Label.Foreground>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="Black" />
                        <GradientStop Offset="1" Color="#FF434848" />
                    </LinearGradientBrush>
                </Label.Foreground>
                <Label.BorderBrush>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="Black" />
                        <GradientStop Offset="1" Color="#FF825555" />
                        <GradientStop Offset="0.35" Color="#FF463636" />
                    </LinearGradientBrush>
                </Label.BorderBrush>
            </Label>
            <Image
                x:Name="ProfileImage"
                Grid.Row="1"
                Width="100"
                Height="91"
                Margin="0,13,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Source="/Resources/settings_icon.png" />
        </Grid>
        <Border
            x:Name="ProfileSelectArea"
            Grid.ColumnSpan="2"
            Margin="100,0,0,0"
            BorderBrush="Black"
            BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="Black" />
                    <GradientStop Offset="1" Color="White" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid x:Name="TitleBarDividerGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="37" />
                    <RowDefinition Height="90" />
                    <RowDefinition Height="200*" />
                </Grid.RowDefinitions>
                <Label
                    x:Name="ProfileSettingsLabel"
                    Width="678"
                    Height="32"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Center"
                    BorderBrush="Black"
                    Content="Select Profile Below"
                    FontFamily="Segoe UI Black"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="Black"
                    RenderTransformOrigin="0.5,0.5">
                    <Label.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="Black" />
                            <GradientStop Offset="1" Color="#FFF9F9F9" />
                        </LinearGradientBrush>
                    </Label.Background>
                    <Label.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" />
                            <SkewTransform />
                            <RotateTransform />
                            <TranslateTransform />
                        </TransformGroup>
                    </Label.RenderTransform>
                </Label>
                <Border
                    x:Name="NewProfileImagePicBorder"
                    Grid.Row="1"
                    Margin="4,3,616,10"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="#FF2F2F2F"
                    BorderBrush="Black"
                    BorderThickness="1">
                    <Button
                        x:Name="SelectNewProfileImageButton"
                        Margin="57,56,-1,-1"
                        Content="+"
                        RenderTransformOrigin="0.5,0.5" Click="SelectNewProfileImageButton_Click">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform />
                                <SkewTransform />
                                <RotateTransform Angle="0" />
                                <TranslateTransform />
                            </TransformGroup>
                        </Button.RenderTransform>
                    </Button>
                </Border>
                <Label
                    x:Name="CreateProfileLabel"
                    Grid.Row="1"
                    Width="267"
                    Height="26"
                    Margin="87,3,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#FFA4A4A4"
                    Content="Create Profile Area" />
                <Label
                    x:Name="UserNameCreationLabel"
                    Grid.Row="1"
                    Width="112"
                    Height="24"
                    Margin="87,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Background="#FFA4A4A4"
                    Content="Profile Name" />
                <TextBox
                    x:Name="NewProfileNameTextBox"
                    Grid.Row="1"
                    Width="112"
                    Margin="87,62,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Text="Type New Name"
                    TextChanged="TextBox_TextChanged"
                    TextWrapping="Wrap" 
                    KeyDown="NewProfileNameTextBox_KeyDown"/>
                <Button
                    x:Name="CreateProfileButton"
                    Grid.Row="1"
                    Width="150"
                    Height="46"
                    Margin="204,34,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    BorderBrush="Black"
                    Content="Create Profile"
                    FontFamily="Segoe UI Black"
                    FontSize="20" Click="CreateProfileButton_Click">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="Black" />
                            <GradientStop Offset="1" Color="#FFFFE6E6" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <ScrollViewer
                    x:Name="ProfileDisplayScrollViewer"
                    Grid.Row="2"
                    Margin="0,0,10,10" />
            </Grid>

        </Border>
    </Grid>
</Window>
